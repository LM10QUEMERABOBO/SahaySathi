<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue"
    android:paddingTop="@dimen/_50sdp"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardElevation="6dp"
        app:cardCornerRadius="12dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_margin="@dimen/_10sdp"
            android:textSize="@dimen/_15sdp"
            android:text="Applicant Details"
            android:textColor="@color/new_red"
            android:textStyle="bold" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/circleImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_gravity="center"
            android:contentDescription="Select image"
            android:src="@drawable/sample_image"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImageViewStyle"/>

        <TextView
            android:id="@+id/detailName"
            android:text="@string/applicant_name"
            android:textColor="@color/new_red"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/detailEmail"
            android:text="@string/applicant_email"
            android:textColor="@color/blue"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/detailPhone"
            android:text="@string/applicant_phone"
            android:textColor="@color/blue"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/detailCity"
            android:text="@string/applicant_city"
            android:layout_marginTop="10dp"
            android:textColor="@color/blue"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/detailSkill"
            android:text="@string/applicant_skill"
            android:layout_marginTop="10dp"
            android:textColor="@color/blue"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/detailExperience"
            android:text="@string/applicant_experience"
            android:layout_marginTop="10dp"
            android:textColor="@color/blue"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_margin="@dimen/_10sdp"
            android:textSize="@dimen/_15sdp"
            android:text="Event Details"
            android:textColor="@color/new_red"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailEventName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blue"
            android:text="Event Name"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/detailEventLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blue"
            android:text="Location of Event"
            android:layout_marginTop="5dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="@dimen/_10sdp"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_gravity="center"
            >
            <Button
                android:id="@+id/accept_button"
                android:background="#008000"
                android:layout_width="@dimen/_120sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginRight="@dimen/_10sdp"
                android:text="@string/applicant_accept_button"
                android:textColor="@color/white"
                android:textSize="@dimen/_16sdp"
                app:cardCornerRadius="12dp"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/regect_button"
                android:background="#FF0000"
                android:layout_width="@dimen/_120sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginLeft="@dimen/_6sdp"
                android:text="@string/applicant_reject_button"
                android:textColor="@color/white"
                android:textSize="@dimen/_16sdp"
                app:cardCornerRadius="12dp"
                app:backgroundTint="@null" />
        </LinearLayout>


    </LinearLayout>



    </androidx.cardview.widget.CardView>


</ScrollView>