        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/userPreferenceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/_12sdp"
                app:cardElevation="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_12sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

            <!-- HEADER -->

            <TextView
                android:id="@+id/dropUserPreference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/new_red"
                android:text="@string/setting_user_preference"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp"/>


                <LinearLayout
                    android:id="@+id/formUserPreference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="@color/white"
                    android:orientation="vertical">
                    <!-- Dark Mode -->
                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:text="@string/setting_switch_mode"
                        android:textColor="@color/new_red"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:ignore="UseSwitchCompatOrMaterialXml" />
                    <!-- Notifications -->
                    <Switch
                        android:id="@+id/switchNotifications"
                        android:text="@string/setting_switch_notifications"
                        android:textColor="@color/new_red"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:ignore="UseSwitchCompatOrMaterialXml" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- NGO DETAILS CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNgoDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_12sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <!-- HEADER -->

                <TextView
                    android:id="@+id/dropNgoDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/new_red"
                    android:text="@string/ngo_organization_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <!-- EXPANDABLE CONTENT -->

                <LinearLayout
                    android:id="@+id/formNgoDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:visibility="gone"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etNgoName"
                        android:layout_width="match_parent"
                        android:drawableStart="@drawable/ic_name"
                        android:drawablePadding="@dimen/_5sdp"
                        android:layout_height="wrap_content"
                        style="@style/editText"
                        android:hint="@string/ngo_organization_name"/>

                    <EditText
                        android:id="@+id/etRegNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="10"
                        style="@style/editText"
                        android:hint="@string/ngo_organization_reg_no"
                        android:layout_marginTop="10dp"/>

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_location"
                        android:drawablePadding="@dimen/_5sdp"
                        style="@style/editText"
                        android:hint="@string/ngo_organization_address"
                        android:layout_marginTop="10dp"/>

                    <Button
                        android:id="@+id/btnUpdateNgo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/button_20"
                        android:gravity="center"
                        app:backgroundTint="@null"
                        android:textColor="@color/white"
                        android:text="@string/ngo_organization_update_btn"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CONTACT CARD -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_4sdp"
            android:layout_marginBottom="@dimen/_12sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dropContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/new_red"
                    android:text="@string/ngo_contact_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formContact"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_call"
                        android:drawablePadding="@dimen/_5sdp"
                        android:maxLength="10"
                        style="@style/editText"
                        android:hint="@string/ngo_contact_phone"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="@dimen/_5sdp"
                        style="@style/editText"
                        android:hint="@string/ngo_contact_email"
                        android:enabled="false"
                        android:layout_marginTop="10dp"/>

                    <Button
                        android:id="@+id/btnUpdateContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/button_20"
                        android:gravity="center"
                        app:backgroundTint="@null"
                        android:textColor="@color/white"
                        android:text="@string/ngo_contact_update_btn"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="@dimen/_250sdp"
            android:layout_gravity="center"
            android:visibility="gone"/>
    </LinearLayout>



    <!-- Logout -->
    <Button
        android:id="@+id/btnLogout"
        android:text="@string/setting_btnLogout"
        style="@style/button_20"
        android:layout_marginHorizontal="@dimen/_50sdp"
        app:backgroundTint="@null"
        android:textStyle="bold"
        android:backgroundTint="@android:color/holo_red_dark"
        android:textColor="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
</ScrollView>