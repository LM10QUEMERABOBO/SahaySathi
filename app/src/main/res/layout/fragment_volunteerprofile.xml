<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- STATUS CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_8sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:visibility="gone"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvProfileStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Review Status"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/new_red" />

                <TextView
                    android:id="@+id/tvProfileStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Not Submitted"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_status_pending" />

                <TextView
                    android:id="@+id/tvReviewInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="After submission, your profile will be reviewed by our background team within 24-48 hours."
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- PROFILE IMAGE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVolunteerLogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_8sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">

                <TextView
                    android:id="@+id/dropVolunteerLogo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Profile Photo"
                    android:textColor="@color/new_red"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/formVolunteerLogo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/circleImage"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:contentDescription="Select profile image"
                        android:focusable="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/sample_image"
                        app:shapeAppearanceOverlay="@style/CircleImageViewStyle" />

                    <Button
                        android:id="@+id/btnUpdateVolunteerLogo"
                        style="@style/button_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:text="Save Photo"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PERSONAL DETAILS -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVolunteerDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_8sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">

                <TextView
                    android:id="@+id/dropVolunteerDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Personal Details"
                    android:textColor="@color/new_red"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/formVolunteerDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etVolunteerName"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full Name"
                        android:inputType="textPersonName" />

                    <EditText
                        android:id="@+id/etAge"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Age"
                        android:inputType="number" />

                    <Spinner
                        android:id="@+id/spGender"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginHorizontal="@dimen/_25sdp"
                        android:padding="12dp" />

                    <Button
                        android:id="@+id/btnUseCurrentLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="Use Current Location"
                        android:textColor="@color/white" />

                    <EditText
                        android:id="@+id/etAddress"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Address"
                        android:inputType="textPostalAddress" />

                    <EditText
                        android:id="@+id/etCity"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="City"
                        android:inputType="textCapWords" />



                    <Button
                        android:id="@+id/btnOpenInMaps"
                        style="@style/button_20"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Open In Google Maps"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />

                    <EditText
                        android:id="@+id/etOccupation"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Occupation / Profession"
                        android:inputType="textCapWords" />

                    <EditText
                        android:id="@+id/etExperience"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Previous Volunteering Experience"
                        android:inputType="textCapSentences" />

                    <Button
                        android:id="@+id/btnUpdateVolunteer"
                        style="@style/button_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:text="Save Personal Details"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CONTACT DETAILS -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_8sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">

                <TextView
                    android:id="@+id/dropContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Contact Information"
                    android:textColor="@color/new_red"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/formContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etPhone"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Phone Number"
                        android:inputType="phone"
                        android:maxLength="10" />

                    <EditText
                        android:id="@+id/etEmail"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:enabled="false"
                        android:hint="Email" />

                    <EditText
                        android:id="@+id/etEmergencyContact"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Emergency Contact Number"
                        android:inputType="phone"
                        android:maxLength="10" />

                    <Button
                        android:id="@+id/btnUpdateContact"
                        style="@style/button_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:text="Save Contact Details"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SKILLS & AVAILABILITY -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardElevation="@dimen/_8sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">

                <TextView
                    android:id="@+id/dropSkills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Skills &amp; Availability"
                    android:textColor="@color/new_red"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/formSkills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Skills"
                        android:textColor="@android:color/black"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSkills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp"
                        app:singleLine="false"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTeaching"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teaching"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMedical"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medical Help"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEventSupport"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Event Support"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFundraising"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fundraising"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAwareness"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Awareness Campaign"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLogistics"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logistics"
                            android:checkable="true" />

                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Availability"
                        android:textColor="@android:color/black"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spAvailability"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/editText"
                        android:layout_marginTop="6dp"
                        android:layout_marginHorizontal="@dimen/_25sdp"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/etPreferredWork"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Preferred Volunteer Work"
                        android:inputType="textCapSentences" />

                    <EditText
                        android:id="@+id/etLanguages"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Languages Known"
                        android:inputType="textCapWords" />

                    <EditText
                        android:id="@+id/etMotivation"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="top|start"
                        android:hint="Why do you want to volunteer?"
                        android:inputType="textMultiLine"
                        android:minLines="3" />

                    <Button
                        android:id="@+id/btnUpdateSkills"
                        style="@style/button_20"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:text="Save Skills Details"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSubmitProfile"
            style="@style/button_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            android:text="Submit Profile For Review"
            android:textColor="@color/white"
            app:backgroundTint="@null" />

    </LinearLayout>
</ScrollView>