<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="@dimen/_20sdp"
    android:background="@color/blue">

    <LinearLayout
        android:id="@+id/postRequestForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- EVENT DETAILS -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dropEvent"
                    android:textColor="@color/new_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Event Details"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formEvent"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="visible">

                    <EditText
                        android:id="@+id/eventName"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Event Name"/>

                    <EditText
                        android:id="@+id/eventDescription"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Event Description"
                        android:layout_marginTop="10dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- LOCATION & TIME -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/dropLocation"
                    android:textColor="@color/new_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location &amp; Time"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formLocation"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/eventLocation"
                        android:layout_width="match_parent"
                        style="@style/editText"
                        android:layout_height="wrap_content"
                        android:hint="Event Location"/>

                    <EditText
                        android:id="@+id/eventDate"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Event Date"
                        android:layout_marginTop="10dp"/>

                    <EditText
                        android:id="@+id/eventTime"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Event Time"
                        android:layout_marginTop="10dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- VOLUNTEER REQUIREMENTS -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/dropVolunteer"
                    android:textColor="@color/new_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Volunteer Requirements"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formVolunteer"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/volunteerCount"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Number of Volunteers"/>

                    <EditText
                        android:id="@+id/experienceRequired"
                        style="@style/editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Required Experience"
                        android:layout_marginTop="10dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- MEDIA UPLOAD -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/dropMedia"
                    android:textColor="@color/new_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Event Images"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formMedia"
                    android:background="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/uploadImage"
                        style="@style/button_20"
                        app:backgroundTint="@null"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Upload Image"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- DEADLINE -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/dropDeadline"
                    android:textColor="@color/new_red"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submission Deadline"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <LinearLayout
                    android:id="@+id/formDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/deadline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Application Deadline"/>

                    <Button
                        android:id="@+id/submitRequest"
                        app:backgroundTint="@null"
                        style="@style/button_20"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Post Volunteer Request"
                        android:layout_marginTop="15dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="@dimen/_250sdp"
            android:layout_gravity="center"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>