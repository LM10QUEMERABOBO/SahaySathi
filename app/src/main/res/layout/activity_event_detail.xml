<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/blue"
        android:layout_marginTop="@dimen/_200sdp"
        android:padding="16dp">

        <!-- Event Title -->
        <TextView
            android:id="@+id/dispEventTitle"
            style="@style/textView_30"
            android:text="Event Title"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <!-- City -->
        <TextView
            android:id="@+id/dispEventCity"
            style="@style/textView_15"
            android:text="City"
            android:layout_marginTop="8dp"
            android:textColor="@color/white" />

        <!-- Description Label -->
        <TextView

            style="@style/textView_15"
            android:text="Description"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <!-- Description -->
        <TextView
            style="@style/textView_15"
            android:id="@+id/dispEventDesc"
            android:text="Event description will appear here"
            android:textColor="@color/white" />

        <!-- Apply Button -->
        <Button
            android:id="@+id/btnApply"
            style="@style/button_10"
            android:text="Apply for Event"
            android:layout_marginTop="24dp"
            android:layout_gravity="center"
            android:background="@color/new_red"
            app:backgroundTint="@null"
            android:textColor="@color/white" />

    </LinearLayout>

</ScrollView>